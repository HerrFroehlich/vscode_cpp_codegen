{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es6",
		"outDir": "out",
		"lib": [
			"es6"
		],
		"sourceMap": true,
		"rootDirs": ["src","test"],
		"baseUrl": "src",
		"paths": {
			"cpp/*":["cpp/*"],
			"io/*":["io/*"],
		},
		"strict": true,
		"noUnusedParameters": true
	},
	"exclude": [
		"node_modules",
		".vscode-test",
		"test/integration/suite/data"
	]
}